# config/secrets.env.template
# Copy this file to secrets.env and fill in your actual values

# Neo4j Configuration (Required)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DB=neo4j

# Ollama Configuration (Required - Local LLM)
# Đảm bảo Ollama đang chạy: ollama serve
# Pull model nếu chưa có: ollama pull mistral
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=mistral

